# San Rafael 360 - Configuración de Entorno Universal

## 🌍 Frontend (Next.js)
# URL de la API de Strapi (Railway/Local)
NEXT_PUBLIC_STRAPI_API_URL=https://sanrafael360-production.up.railway.app
# Token de API generado en Strapi > Settings > API Tokens (Full Access)
STRAPI_API_TOKEN=TU_TOKEN_AQUI
# Llave de Google Maps (Requerida para Mapas Interactivos)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

## 📦 Backend (Strapi 5)
# Secreto para la generación de App (Cualquier cadena larga)
APP_KEYS=key1,key2,key3,key4
# Secreto para Tokens de API
API_TOKEN_SALT=salt1
# Secreto para Cookies de Admin
ADMIN_JWT_SECRET=secret1
# Secreto para JWT de Usuarios
JWT_SECRET=usersecret1

# Database Configuration (Postgres Railway)
DATABASE_URL=postgres://user:pass@host:port/db
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false

# Media Storage (Cloudinary)
CLOUDINARY_NAME=tu_cloud_name
CLOUDINARY_KEY=tu_api_key
CLOUDINARY_SECRET=tu_api_secret
